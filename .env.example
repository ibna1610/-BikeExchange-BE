# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bike_exchange
DB_USER=root
DB_PASSWORD=12345678

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_at_least_64_chars_long_for_security
JWT_EXPIRATION_MS=86400000

# Mail Configuration (Brevo)
BREVO_SMTP_KEY=your_brevo_smtp_key_here

# Frontend URL
FRONTEND_URL=http://localhost:5173
FORGOT_PASSWORD_URL=http://localhost:5173/reset-password

# VNPay Configuration
VNP_TMN_CODE=your_vnpay_tmn_code_here
VNP_HASH_SECRET=your_vnpay_hash_secret_here
VNP_RETURN_URL=http://localhost:5173/payment-success
VNP_IPN_URL=http://localhost:8080/api/vnpay/ipn

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
